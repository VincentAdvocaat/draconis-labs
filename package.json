{
  "name": "draconis-labs",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.10.0",
  "scripts": {
    "dev": "corepack pnpm --parallel --filter @draconis/api --filter @draconis/planner dev",
