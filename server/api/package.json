{
  "name": "@draconis/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "oxlint src tests",
    "test": "vitest run",
    "openapi:update": "tsx scripts/update-openapi-snapshot.ts"
  },
  "dependencies": {
    "@draconis/shared": "workspace:*",
    "@fastify/cors": "^11.3.0",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^5.2.5",
    "better-sqlite3": "^12.11.1",
    "drizzle-orm": "^0.45.2",
    "fastify": "^5.10.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24.13.3",
    "oxlint": "^1.73.0",
    "tsx": "^4.23.0",
    "typescript": "~6.0.3",
    "vitest": "^4.0.18"
  }
}
